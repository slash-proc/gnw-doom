# --- WADs (licensing) -------------------------------------------------------
# The shareware IWAD is the one WAD id Software permits redistributing;
# every other WAD (registered/Ultimate/re-release/DOOM II) must stay untracked.
**/*.wad
!/doom1-shareware.wad
# WHD/WHX are WAD-derived: same licensing rule, and reproducible via whd_gen.
*.whd
*.whx

